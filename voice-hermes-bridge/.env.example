# Hermes 本地 HTTP 接口。推荐方式：语音桥直接调用 Hermes，能拿到回复并播报。
HERMES_API_URL=http://127.0.0.1:8000/chat

# 飞书自定义机器人 webhook。如果没有 Hermes HTTP 接口，可先把语音识别结果发到飞书群。
FEISHU_WEBHOOK_URL=

# Coqui TTS 中文模型。首次运行会自动下载。
TTS_MODEL_NAME=tts_models/zh-CN/baker/tacotron2-DDC-GST

# DeepSpeech 模型路径
DEEPSPEECH_MODEL=models/deepspeech-0.9.3-models.pbmm
DEEPSPEECH_SCORER=models/deepspeech-0.9.3-models.scorer

# 录音参数
RECORD_SECONDS=5
SAMPLE_RATE=16000
